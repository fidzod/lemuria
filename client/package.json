		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.9.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@fontsource/jetbrains-mono": "^5.2.8",
		"@fontsource/open-sans": "^5.2.7",
		"@lucide/svelte": "^1.3.0"
	}
}
